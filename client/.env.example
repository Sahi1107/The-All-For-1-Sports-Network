# ─────────────────────────────────────────────────────────────────────────────
# All For 1 — Client Environment Variables
#
# Copy this file to .env.local and fill in any values you need.
# NEVER put server-side secrets here — anything prefixed with VITE_ is
# bundled into the JavaScript shipped to every user's browser.
# ─────────────────────────────────────────────────────────────────────────────


# ── API Base URL ──────────────────────────────────────────────────────────────
#
# Only needed when the client is served from a different origin than the API
# (e.g. a CDN or separate container).  Leave blank for local development —
# the Vite dev proxy forwards /api automatically.
#
# In production set this to your public API origin, e.g.:
#   VITE_API_URL=https://api.allfor1.com
#
# NEVER set this to a localhost address in production.
# NEVER put secret values (API keys, JWT secrets, database URLs) here.
#
VITE_API_URL=

# ── Firebase Client SDK ────────────────────────────────────────────────────────
#
# These values come from your Firebase project's web app configuration.
# Firebase Console → Project Settings → Your apps → Web → SDK setup and config
#
# These are NOT secrets — they are safe to include in client-side code.
# They identify your Firebase project but do not grant any elevated access.
#
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
