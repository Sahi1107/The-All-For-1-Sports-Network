# ─────────────────────────────────────────────────────────────────────────────
# All For 1 — Server Environment Variables
#
# Copy this file to .env and fill in every value before running the server.
# NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ───────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000
# Set to 1 when behind Nginx, Caddy, Cloudflare, or an AWS ALB.
TRUST_PROXY=0


# ── Database ─────────────────────────────────────────────────────────────────
#
# Run PostgreSQL in a private subnet — never expose it to the public internet.
# In production append ?sslmode=require.
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/allfor1?schema=public"


# ── Firebase Admin SDK ────────────────────────────────────────────────────────
#
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" — download the JSON file
# 3. Copy the three values below from that file
# 4. For FIREBASE_PRIVATE_KEY, paste the entire "private_key" value including
#    the -----BEGIN/END----- lines. Keep the literal \n characters as-is;
#    the server replaces them with real newlines at startup.
#
# These credentials give your server full admin access to your Firebase project.
# Guard them like a root password — NEVER expose them in frontend code.
#
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"


# ── CORS ─────────────────────────────────────────────────────────────────────
#
# Exact origin of the frontend. Must NOT end with a trailing slash.
# In production this must be your live domain, e.g. https://allfor1.com
CLIENT_URL=http://localhost:5173


# ── Cloudinary ───────────────────────────────────────────────────────────────
#
# Found in the Cloudinary dashboard › Settings › API Keys.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# ── Logging ───────────────────────────────────────────────────────────────────
#
# Accepted levels: error | warn | info | http | verbose | debug
LOG_LEVEL=debug
